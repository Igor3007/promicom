extends ../layouts/default
include ../helpers/mixins
include ../../blocks/components/breadcrumbs/breadcrumbs.pug
include ../../blocks/components/form/form.pug
include ../../blocks/components/checkbox/checkbox.pug
include ../../blocks/components/headers/headers.pug
include ../../blocks/components/table/table.pug
include ../../blocks/components/popup/popup.pug

block variables
    - const title = "Проекты - Metrium Premium"

block styles
    link(rel="stylesheet" href="static/styles/metrium.css")

block content

    .page-breadcrumbs
        ._container
            +breadcrumb([
                {
                    link: "/",
                    text: "Главная",
                },
                {
                    link: "/projects",
                    text: "Проекты",
                },
                {
                    link: "#",
                    text: "Metrium Premium",
                    isActive: true,
                }
            ], 'wow experience')


    include ../../blocks/modules/metrium/metrium


    +callbackPopup()

block scripts
    script(src="static/js/main.js")
    script(src="static/js/homesPro.js")
